# PostgreSQL
POSTGRES_USER=gaia
POSTGRES_PASSWORD=gaiapass
POSTGRES_DB=gaia_metadata

# Security - generate with: openssl rand -hex 32
SECRET_KEY=changeme-use-openssl-rand-hex-32-in-production
# Session duration in minutes. 525600 = 1 year (effectively no expiry)
ACCESS_TOKEN_EXPIRE_MINUTES=525600

# gaia-acquisition NMEA ingestor (UDP)
NMEA_HOST=host.docker.internal
NMEA_PORT=10115

# gaia-acquisition REST API
# NOTE: from inside Docker use host.docker.internal, NOT localhost
GAIA_ACQUISITION_URL=http://host.docker.internal:8080

# App
APP_PORT=8088
VESSEL_NAME=Gaia Blu

# pgAdmin (admin profile only — start with: docker compose --profile admin up -d)
PGADMIN_EMAIL=admin@gaiablu.local
PGADMIN_PASSWORD=gaiaadmin
PGADMIN_PORT=5050
